# Copy to `.env` next to the `compose.yaml` you run (repo root or `docker-lab/`).
# `.env` is gitignored — never commit real passwords or Render URLs with secrets.
#
# Docker Compose substitutes ${DATABASE_URL} automatically when you `docker compose up`.

# --- Local Compose (default): API shares Postgres network stack → loopback is OK
DATABASE_URL=postgresql://docker_lab_postgres_user:R2W5YRzVeaJDCBLK0Layyaleuc0TdJmQ@dpg-d860s6p9rddc73et87l0-a/docker_lab_postgres
ALLOW_LOOPBACK_DATABASE=1

# --- Optional: host Postgres publish port when 5432 is taken locally
# LAB_PG_PUBLISH=5433

# --- Point your laptop at Render Postgres (External Database URL from dashboard).
# Do NOT use this as DATABASE_URL on the Render web service — there use Internal URL
# or link the DB in Environment. Uncomment and paste your External URL only for local tools:
# DATABASE_URL=postgresql://USER:PASSWORD@dpg-xxxxx.REGION-postgres.render.com/docker_lab
# (omit ALLOW_LOOPBACK_DATABASE or set 0 — host is not 127.0.0.1)

# From your host to local Compose Postgres (not the container loopback URL):
# psql -h 127.0.0.1 -p 5433 -U postgres -d docker_lab
