# Copy to `.env` if your tooling loads it (never commit real `.env`).
# Compose sets DATABASE_URL inline — pattern matches `network_mode: service:db`:

DATABASE_URL=postgresql+psycopg2://postgres:postgres@127.0.0.1:5432/docker_lab

# Optional: host port for Postgres when something else uses 5432 (default in compose is 5433).
# LAB_PG_PUBLISH=5433
